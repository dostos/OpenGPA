{
  "manifest_version": 3,
  "name": "Beholder WebGL Debugger",
  "version": "0.1.0",
  "description": "Beholder - WebGL interception",
  "permissions": ["activeTab"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["interceptor.js", "bhdr-trace.js"],
    "matches": ["<all_urls>"]
  }]
}
